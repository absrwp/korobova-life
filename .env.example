# Скопируйте в .env.local и заполните реальными значениями.
# .env.local — в .gitignore, не попадёт в репозиторий.

# Telegram bot для уведомлений о заявках с форм сайта.
# 1. Создайте бота через @BotFather → /newbot → получите токен
VITE_TG_BOT_TOKEN=

# 2. Узнайте CHAT_ID:
#    - откройте бота → нажмите Start → напишите ему любое сообщение
#    - откройте https://api.telegram.org/bot<ТОКЕН>/getUpdates
#    - найдите "chat":{"id": <число>} — это CHAT_ID
VITE_TG_CHAT_ID=
